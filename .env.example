# ==========================================
# 🌍 NewAPI 全球化平台・环境变量模板
# ⚠️ 安全规范：此文件仅含占位符，真实值请填入本地 .env（已加入 .gitignore）
# 使用方法：cp .env.example .env && vim .env
# ==========================================

# === 基础标识 ===
PROJECT_NAME="newapi-global"
DEFAULT_ADMIN_PASSWORD="ChangeMe_123!@#"

# === 数据库配置 (MySQL) ===
# 各区域独立设置，部署脚本会自动根据 REGION 覆盖
DB_ROOT_PASS="YourStrongDbPass123!"
DB_PORT="3306"
DB_NAME_TEMPLATE="newapi_{REGION}"

# === 缓存配置 (Redis) ===
REDIS_PASS="YourStrongRedisPass123!"
REDIS_PORT="6379"

# === NetBird 零信任网络 ===
NETBIRD_MGMT_URL="https://mgmt.your-domain.com"
NETBIRD_SETUP_KEY="nb-setup-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
NETBIRD_RELAY_IP="100.64.255.5"
NETBIRD_CIDR="100.64.0.0/10"

# === 全球配置同步密钥 ===
# 用于全球层向各区域加密下发渠道/路由配置（不含用户业务数据）
GLOBAL_SYNC_TOKEN="global-sync-secret-xxxxxxxx"
GLOBAL_MGMT_IP="100.64.255.10"

# === 监控与告警 ===
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASS="GrafanaSecurePass123!"
# 钉钉/企微机器人 Webhook（替换为你的实际 token）
DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN_HERE"

# === 区域自动注入变量（通常无需手动改，由 deploy-region.sh 生成） ===
REGION="cn"                 # 当前区域: cn | us | eu | ap
REGION_BASE_IP="100.64.1"   # 对应区域 NetBird 网段前缀
REGION_ID="1"               # 区域数字 ID (cn=1, us=2, eu=3, ap=4)
